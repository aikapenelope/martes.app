# martes.app — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# El .env se configura en Coolify UI → proyecto → servicio → Environment Variables.

# ============================================================
# PostgreSQL
# ============================================================
PG_PASSWORD=cambiar_en_produccion

# ============================================================
# Meta-agente
# ============================================================
# API key de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Token del bot de Telegram del META-AGENTE (no de los tenants)
# Crear con @BotFather en Telegram
META_AGENT_TELEGRAM_TOKEN=123456:ABC-DEF

# Secret para validar webhooks de Telegram en producción (APP_ENV=production).
# Agno valida el header X-Telegram-Bot-Api-Secret-Token con este valor.
# Generar: openssl rand -hex 32
# Registrar: curl "https://api.telegram.org/bot${TOKEN}/setWebhook
#   ?url=https://api.martes.app/telegram/webhook&secret_token=${TELEGRAM_WEBHOOK_SECRET_TOKEN}"
TELEGRAM_WEBHOOK_SECRET_TOKEN=generar_con_openssl_rand_hex_32

# Entorno: development (polling Telegram) | production (webhook via Coolify)
APP_ENV=production
