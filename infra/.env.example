# martes.app — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# El .env se configura en Coolify UI → proyecto → servicio → Environment Variables.

# ============================================================
# PostgreSQL
# ============================================================
PG_PASSWORD=cambiar_en_produccion

# ============================================================
# Meta-agente
# ============================================================
# API key de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Token del bot de Telegram del META-AGENTE (no de los tenants)
# Crear con @BotFather en Telegram
META_AGENT_TELEGRAM_TOKEN=123456:ABC-DEF

# IDs de Telegram autorizados para hablar al meta-agente.
# Formato: IDs numéricos separados por coma.
# Obtener tu ID: habla con @userinfobot en Telegram.
# Sin esto cualquier usuario puede hablar al bot — obligatorio en producción.
TELEGRAM_ADMIN_IDS=563825119

# Secret para validar webhooks de Telegram en producción (APP_ENV=production).
# Agno valida el header X-Telegram-Bot-Api-Secret-Token en cada webhook.
# Generar: openssl rand -hex 32
# Registrar: curl "https://api.telegram.org/bot${TOKEN}/setWebhook
#   ?url=https://api.martes.app/telegram/webhook&secret_token=${TELEGRAM_WEBHOOK_SECRET_TOKEN}"
TELEGRAM_WEBHOOK_SECRET_TOKEN=generar_con_openssl_rand_hex_32

# Entorno: development (polling Telegram) | production (webhook via Coolify)
APP_ENV=production

# ============================================================
# SeaweedFS — Object storage S3-compatible para backups de tenants
# Ref: https://github.com/seaweedfs/seaweedfs#quick-start-for-s3-api-on-docker
# ============================================================
# Generar credenciales únicas (una vez, guardarlas seguras):
#   openssl rand -hex 16   → SEAWEEDFS_ACCESS_KEY
#   openssl rand -hex 32   → SEAWEEDFS_SECRET_KEY
#
# El mismo par de valores se configura en Coolify UI → Environment Variables.
# SeaweedFS los usa para autenticar peticiones S3.
# El meta-agente los usa para conectar al endpoint http://seaweedfs:8333.
SEAWEEDFS_ACCESS_KEY=generar_con_openssl_rand_hex_16
SEAWEEDFS_SECRET_KEY=generar_con_openssl_rand_hex_32
