# martes.app — Variables de entorno
# Copia este archivo como .env y completa los valores

# ============================================================
# PostgreSQL
# ============================================================
PG_PASSWORD=cambiar_en_produccion

# ============================================================
# Meta-agente
# ============================================================
# API key de OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Token del bot de Telegram del META-AGENTE (no de los tenants)
# Crear con @BotFather en Telegram
META_AGENT_TELEGRAM_TOKEN=123456:ABC-DEF

# Entorno: development (polling) o production (webhook)
APP_ENV=development

# ============================================================
# Traefik (solo produccion)
# ============================================================
ACME_EMAIL=admin@martes.app

# ============================================================
# Paths (normalmente no cambiar)
# ============================================================
# TENANTS_BASE_PATH=/var/lib/martes/tenants
# HERMES_IMAGE=nousresearch/hermes-agent:0.14.0
