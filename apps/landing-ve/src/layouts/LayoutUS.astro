---
import '../styles/global.css';
export interface Props { title?: string; description?: string; }
const {
  title = 'martes // Tu negocio, sin el caos',
  description = 'Ecosistema operativo con agentes AI para negocios venezolanos.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@100;300;400;700&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body class="ve-mode-body font-mono text-sm antialiased">
  <slot />
</body>
</html>
