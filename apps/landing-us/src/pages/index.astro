  { name: 'Calendar',  color: '#4285F4', icon: '📅' },
  { name: 'Sheets',    color: '#34A853', icon: '⊞' },
  { name: 'Teams',     color: '#6264A7', icon: 'T' },
  { name: 'Email',     color: '#FF6B35', icon: '✉' },
