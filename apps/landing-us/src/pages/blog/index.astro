---
// Blog hub — /blog
// Inspirado en MagicUI blog template: card grid, tag filter, featured post
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const featured = allPosts[0];
const rest     = allPosts.slice(1);
const allTags  = [...new Set(allPosts.flatMap(p => p.data.tags))].sort();

function readingTime(content: string) {
  const words = content.split(/\s+/).length;
  return Math.ceil(words / 200);
}

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('es', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Layout title="Blog — martes.app" description="Novedades, casos de uso y guías del ecosistema martes.app.">

  <header class="fixed top-0 w-full z-40 border-b border-sys-border bg-sys-bg/90 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-sys-text font-bold tracking-widest uppercase text-sm">
        <span class="w-2 h-2 bg-sys-accent-1 rounded-full"></span>martes<span class="text-sys-accent-1">.app</span>
      </a>
      <nav class="flex items-center gap-6 text-xs font-mono">
        <a href="/" class="text-sys-muted hover:text-sys-accent-1 uppercase tracking-wider">Landing</a>
        <a href="/docs" class="text-sys-muted hover:text-sys-accent-1 uppercase tracking-wider">Docs</a>
        <a href="/us-version" class="text-sys-muted hover:text-sys-accent-1 uppercase tracking-wider text-[10px] border-l border-sys-border pl-4">🇺🇸 US</a>
      </nav>
    </div>
  </header>

  <div class="pt-24 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">

    <div class="mb-12">
      <div class="text-xs text-sys-muted font-mono tracking-widest uppercase mb-3">// Blog</div>
      <h1 class="text-4xl sm:text-5xl font-bold font-sans text-white mb-4">Novedades y guías</h1>
      <p class="text-sys-muted text-lg max-w-2xl">Novedades, casos de uso y guías del ecosistema martes.app.</p>
    </div>

    {featured && (
      <a href={`/blog/${featured.slug}`} class="group block border border-sys-border bg-sys-surface/30 p-6 mb-8 hover:border-sys-accent-1 transition-all">
        <div class="flex items-center gap-3 mb-3">
          <span class="px-2 py-0.5 text-[10px] font-mono border border-sys-accent-1 text-sys-accent-1">DESTACADO</span>
          <span class="text-[10px] font-mono text-sys-muted">{formatDate(featured.data.date)}</span>
        </div>
        <h2 class="text-2xl font-bold text-white group-hover:text-sys-accent-1 transition-colors mb-2">{featured.data.title}</h2>
        {featured.data.description && <p class="text-sys-muted">{featured.data.description}</p>}
      </a>
    )}

    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {allTags.map(tag => (
          <a href={`/blog?tag=${tag}`} class="px-2.5 py-0.5 text-[10px] font-mono border border-sys-border text-sys-muted hover:border-sys-accent-1 hover:text-sys-accent-1 transition-colors">{tag}</a>
        ))}
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {rest.map(post => (
        <a href={`/blog/${post.slug}`} class="group block border border-sys-border bg-sys-surface/30 p-5 hover:border-sys-accent-1 hover:bg-sys-surface transition-all">
          <div class="flex items-center gap-2 mb-3 text-[10px] font-mono text-sys-muted">
            <span>{formatDate(post.data.date)}</span>
            {post.data.tags?.[0] && <><span>·</span><span class="text-sys-accent-1">{post.data.tags[0]}</span></>}
          </div>
          <h3 class="text-white font-bold mb-2 group-hover:text-sys-accent-1 transition-colors">{post.data.title}</h3>
          {post.data.description && <p class="text-sys-muted text-xs leading-relaxed line-clamp-3">{post.data.description}</p>}
        </a>
      ))}
    </div>

  </div>

  <footer class="border-t border-sys-border py-6 text-center text-xs font-mono text-sys-muted">&copy; 2026 martes.app</footer>
</Layout>
