---
import DocsLayout from '../../layouts/DocsLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const docs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
  return docs.map(doc => ({
    params: { slug: doc.slug },
    props: { doc },
  }));
}

interface Props { doc: CollectionEntry<'docs'>; }
const { doc } = Astro.props;
const { Content } = await doc.render();
---
<DocsLayout title={doc.data.title} description={doc.data.description} currentSlug={doc.slug}>
  <div class="max-w-3xl">
    <div class="text-xs text-sys-muted font-mono tracking-widest uppercase mb-3">// {doc.data.section} //</div>
    <Content />
  </div>
</DocsLayout>
