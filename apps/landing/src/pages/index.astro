---

<Layout
  title="martes.app — Custom AI Software for Your Company"
  description="We build custom AI agents, AI-powered CRMs and integrations for LATAM companies."
>
<canvas id="bg-canvas"></canvas>
<div class="scanline-overlay"></div>

<!-- NAV -->
<nav class="fixed top-0 w-full z-40 border-b border-sys-border bg-sys-bg/85 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center gap-3">
        <div class="pulse-ring w-2 h-2 bg-sys-accent-1 rounded-full"></div>
        <span class="text-sys-text font-bold tracking-widest uppercase text-sm font-mono">
          martes<span class="text-sys-accent-1">.</span>app
        </span>
      </div>
      <div class="hidden md:flex items-center gap-6 text-xs font-mono">
        <a href="#servicios"     class="text-sys-muted hover:text-sys-accent-1 transition-colors uppercase tracking-wider">Services</a>
        <a href="#roi"           class="text-sys-muted hover:text-sys-accent-1 transition-colors uppercase tracking-wider">ROI</a>
        <a href="#integrations" class="text-sys-muted hover:text-sys-accent-1 transition-colors uppercase tracking-wider">Integrations</a>
        <a href="#use-cases"    class="text-sys-muted hover:text-sys-accent-1 transition-colors uppercase tracking-wider">Use Cases</a>
        <a href="#tecnologia"    class="text-sys-muted hover:text-sys-accent-1 transition-colors uppercase tracking-wider">Tech</a>
        <a href="/docs"          class="text-sys-muted hover:text-sys-accent-1 transition-colors uppercase tracking-wider">Docs</a>
        <a href="/blog"          class="text-sys-muted hover:text-sys-accent-1 transition-colors uppercase tracking-wider">Blog</a>
        <a href="#contacto"      class="bg-sys-accent-1 text-black px-4 py-2 font-bold uppercase tracking-wider hover:bg-white transition-colors">
          Talk to us
        </a>
      </div>
      <a href="#contacto" class="md:hidden bg-sys-accent-1 text-black px-3 py-2 font-bold uppercase text-[10px] tracking-wider hover:bg-white transition-colors">
        Contact
      </a>
    </div>
  </div>
</nav>

<!-- HERO -->
<main class="relative pt-32 pb-8 sm:pt-44 overflow-hidden">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[700px] bg-hero-glow rounded-full blur-[120px] opacity-15 animate-pulse-slow pointer-events-none"></div>
  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <div class="mb-5 inline-flex items-center gap-2 border border-sys-border/60 px-4 py-1.5 rounded-full text-xs text-sys-muted font-mono">
      <span class="w-1.5 h-1.5 rounded-full bg-sys-accent-2 animate-pulse"></span>
      POWERED BY HERMES AGENT · NousResearch · 165K ⭐
    </div>
    <h1 class="text-5xl sm:text-7xl lg:text-[88px] font-black tracking-tighter mb-6 font-sans leading-none">
      <span class="text-transparent bg-clip-text bg-gradient-to-br from-white via-gray-200 to-gray-500">CUSTOM AI</span><br>
      <span class="font-mono text-white glitch-hover">SOFTWARE</span>
    </h1>
    <p class="mt-2 max-w-2xl mx-auto text-lg sm:text-xl text-sys-muted font-light leading-relaxed mb-4">
      We build custom AI agents for your company — AI-powered CRM,
      tailored automations, integrations with Google Workspace, WhatsApp and 20+ tools.
      All powered by Hermes Agent, the most advanced open-source AI agent.
    </p>
    <div class="flex flex-col sm:flex-row justify-center gap-3 mb-16">
      <a href="#contacto" class="tech-border inline-flex items-center justify-center px-8 py-4 border border-sys-accent-1 text-sys-accent-1 hover:bg-sys-accent-1 hover:text-black font-bold uppercase tracking-widest transition-all text-sm">
        Get a 30-min scoping call
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="square" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </a>
      <a href="/docs" class="inline-flex items-center justify-center px-8 py-4 border border-sys-border text-sys-muted hover:border-sys-text hover:text-sys-text font-bold uppercase tracking-widest transition-all text-sm">
        See the docs
      </a>
    </div>
    <div class="relative mx-auto max-w-3xl">
      <div class="absolute inset-0 bg-gradient-to-t from-sys-bg via-transparent to-transparent z-10 pointer-events-none h-16 bottom-0 top-auto"></div>
      <div class="border border-sys-border bg-sys-surface/30 overflow-hidden shadow-2xl">
        <div class="border-b border-sys-border bg-sys-surface px-4 py-2 flex items-center justify-between text-[10px] font-mono text-sys-muted">
          <div class="flex gap-2 items-center">
            <span class="w-2.5 h-2.5 rounded-full bg-sys-accent-3/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-green-500/60"></span>
          </div>
          <span>martes.app // HERMES_DEPLOYMENT_LOG</span>
          <span class="text-green-500">● ONLINE</span>
        </div>
        <div class="p-5 font-mono text-xs h-44 overflow-hidden" id="terminal-output">
          <div class="text-sys-muted">&gt; Initializing Hermes v0.14.0...</div>
          <div class="text-sys-muted">&gt; Loading custom CRM schema...</div>
          <div class="text-sys-muted">&gt; Connecting Google Workspace...</div>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- MARQUEE -->
<section class="py-16 border-y border-sys-border/40 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 mb-4 text-center">
    <p class="text-[10px] font-mono text-sys-muted uppercase tracking-widest">
      Native integrations · 22+ platforms · OAuth 2.1 · MCP
    </p>
  </div>
  <div class="marquee-wrapper mb-3">
    <div class="marquee-track">
      {[...row1, ...row1].map((p, i) => (
        <div class={`flex items-center gap-2 px-4 py-2 border border-sys-border/60 bg-sys-surface/40 shrink-0 whitespace-nowrap icon-float icon-float-delay-${(i % 6) + 1} hover:border-sys-accent-1/60 transition-colors cursor-default`} style={`border-color: ${p.color}22;`}>
          <span class="text-sm" style={`color: ${p.color};`}>{p.icon}</span>
          <span class="text-[11px] font-mono" style={`color: ${p.color};`}>{p.name}</span>
        </div>
      ))}
    </div>
  </div>
  <div class="marquee-wrapper">
    <div class="marquee-track-rev">
      {[...row2, ...row2].map((p, i) => (
        <div class={`flex items-center gap-2 px-4 py-2 border border-sys-border/60 bg-sys-surface/40 shrink-0 whitespace-nowrap icon-float icon-float-delay-${(i % 6) + 1} hover:border-sys-accent-1/60 transition-colors cursor-default`} style={`border-color: ${p.color}22;`}>
          <span class="text-sm" style={`color: ${p.color};`}>{p.icon}</span>
          <span class="text-[11px] font-mono" style={`color: ${p.color};`}>{p.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SERVICES -->
<section id="servicios" class="py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-14 text-center">
      <div class="text-[10px] font-mono text-sys-muted uppercase tracking-widest mb-3">01 // What we build</div>
      <h2 class="text-4xl font-black font-sans text-white">CUSTOM SOFTWARE,<br>NOT TEMPLATES</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div class="border border-sys-border bg-sys-surface/20 p-7 hover:border-sys-accent-1/50 transition-all group relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-sys-accent-1/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <div class="relative z-10">
          <div class="w-10 h-10 bg-sys-accent-1/10 border border-sys-accent-1/30 flex items-center justify-center mb-5 icon-float"><span class="text-sys-accent-1 text-lg">⊡</span></div>
          <h3 class="text-xl font-bold text-white mb-3 font-sans">AI-Powered CRM</h3>
          <p class="text-sys-muted text-sm leading-relaxed mb-4">
            We design your CRM from scratch with Hermes at its core. The agent answers customers,
            updates records, generates reports and scales with you. No licenses, yours completely.
          </p>
          <div class="flex flex-wrap gap-1.5 text-[10px] font-mono">
            {['Sales pipeline', 'Auto tracking', 'AI reports', 'Native WhatsApp'].map(t => (
              <span class="px-2 py-0.5 bg-sys-accent-1/10 text-sys-accent-1 border border-sys-accent-1/20">{t}</span>
            ))}
          </div>
        </div>
      </div>
      <div class="border border-sys-border bg-sys-surface/20 p-7 hover:border-sys-accent-2/50 transition-all group relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-sys-accent-2/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <div class="relative z-10">
          <div class="w-10 h-10 bg-sys-accent-2/10 border border-sys-accent-2/30 flex items-center justify-center mb-5 icon-float icon-float-delay-2"><span class="text-sys-accent-2 text-lg">💬</span></div>
          <h3 class="text-xl font-bold text-white mb-3 font-sans">Customer Service Agent</h3>
          <p class="text-sys-muted text-sm leading-relaxed mb-4">
            Hermes responds on Telegram and WhatsApp 24/7 with the exact knowledge of your company.
            Persistent memory: it remembers every customer, order and history.
          </p>
          <div class="flex flex-wrap gap-1.5 text-[10px] font-mono">
            {['Telegram', 'WhatsApp', '24/7 memory', 'Human escalation'].map(t => (
              <span class="px-2 py-0.5 bg-sys-accent-2/10 text-sys-accent-2 border border-sys-accent-2/20">{t}</span>
            ))}
          </div>
        </div>
      </div>
      <div class="border border-sys-border bg-sys-surface/20 p-7 hover:border-[#4285F4]/50 transition-all group relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#4285F4]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <div class="relative z-10">
          <div class="flex items-center gap-2 mb-5">
            {[
              { letter: 'G', color: '#4285F4' },
              { letter: 'M', color: '#EA4335' },
              { letter: '▲', color: '#FBBC04' },
              { letter: '⊞', color: '#34A853' },
            ].map((g, idx) => (
              <div class={`w-8 h-8 flex items-center justify-center border text-xs font-bold icon-float icon-float-delay-${idx+1}`} style={`color: ${g.color}; border-color: ${g.color}33; background: ${g.color}11;`}>
                {g.letter}
              </div>
            ))}
          </div>
          <h3 class="text-xl font-bold text-white mb-3 font-sans">Google Workspace + AI</h3>
          <p class="text-sys-muted text-sm leading-relaxed mb-4">
            The agent reads and writes to Gmail, Calendar, Drive, Docs and Sheets. It automates complete
            flows: "when an email arrives from a supplier, create a row in Sheets and a task in Calendar".
          </p>
          <div class="flex flex-wrap gap-1.5 text-[10px] font-mono">
            {['Gmail', 'Google Sheets', 'Google Drive', 'Google Calendar'].map(t => (
              <span class="px-2 py-0.5 bg-[#4285F4]/10 text-[#4285F4] border border-[#4285F4]/20">{t}</span>
            ))}
          </div>
        </div>
      </div>
      <div class="border border-sys-border bg-sys-surface/20 p-7 hover:border-sys-accent-3/50 transition-all group relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-sys-accent-3/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <div class="relative z-10">
          <div class="w-10 h-10 bg-sys-accent-3/10 border border-sys-accent-3/30 flex items-center justify-center mb-5 icon-float icon-float-delay-3"><span class="text-sys-accent-3 text-lg">⚡</span></div>
          <h3 class="text-xl font-bold text-white mb-3 font-sans">Custom Automations</h3>
          <p class="text-sys-muted text-sm leading-relaxed mb-4">
            Workflows designed for your specific company. Automatic reports, alerts,
            data sync, web scraping, document generation.
          </p>
          <div class="flex flex-wrap gap-1.5 text-[10px] font-mono">
            {['Cron scheduler', 'Web scraping', 'Auto docs', 'Telegram alerts'].map(t => (
              <span class="px-2 py-0.5 bg-sys-accent-3/10 text-sys-accent-3 border border-sys-accent-3/20">{t}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

