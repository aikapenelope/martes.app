  { name: 'Signal',    color: '#2592E9', icon: '🔒' },
  { name: 'Gmail',     color: '#EA4335', icon: 'M' },
  { name: 'Drive',     color: '#FBBC04', icon: '▲' },
  { name: 'Calendar',  color: '#4285F4', icon: '📅' },
