---
// Blog hub — /blog
// Inspired by MagicUI blog template: card grid, tag filter, featured post
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const featured = allPosts[0];
const rest     = allPosts.slice(1);
const allTags  = [...new Set(allPosts.flatMap(p => p.data.tags))].sort();

// Helpers
function readingTime(content: string) {
  const words = content.split(/\s+/).length;
  return Math.ceil(words / 200);
}
---

<Layout title="Blog — martes.app" description="Articles on custom AI software, Hermes Agent, tutorials and use cases for LATAM companies.">

<!-- NAV -->
<header class="fixed top-0 w-full z-40 border-b border-sys-border bg-sys-bg/95 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a href="/" class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-sys-accent-1 rounded-full"></span>
        <span class="font-bold tracking-widest uppercase text-xs font-mono text-sys-text">martes<span class="text-sys-accent-1">.</span>app</span>
      </a>
      <span class="text-sys-border text-xs">/</span>
      <span class="text-sys-muted text-xs font-mono">Blog</span>
    </div>
    <div class="flex items-center gap-4 text-xs font-mono">
      <a href="/docs"      class="text-sys-muted hover:text-sys-accent-1 transition-colors hidden sm:block">Docs</a>
      <a href="/#contacto" class="bg-sys-accent-1 text-black px-3 py-1.5 font-bold uppercase hover:bg-white transition-colors text-[10px] tracking-wider">
        Contact
      </a>
    </div>
  </div>
</header>

<div class="pt-14 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14">

  <!-- Header -->
  <div class="mb-12">
    <p class="text-[10px] font-mono text-sys-muted uppercase tracking-[0.2em] mb-3">SYS.BLOG // martes.app</p>
    <h1 class="text-[42px] font-black font-sans text-white leading-none mb-4">Blog</h1>
    <p class="text-sys-muted text-sm max-w-lg font-sans leading-relaxed">
      Articles on custom AI software, Hermes Agent, tutorials and use cases for LATAM companies.
    </p>
  </div>

  <!-- Tag filter -->
  <div class="flex gap-2 flex-wrap mb-12 font-mono" id="tag-filters">
    <button data-tag="" class="tag-btn px-3 py-1 border border-sys-accent-1 text-sys-accent-1 text-[11px] transition-all">
      All&nbsp;<span class="opacity-60">({allPosts.length})</span>
    </button>
    {allTags.map(tag => (
      <button
        data-tag={tag}
        class="tag-btn px-3 py-1 border border-sys-border text-sys-muted hover:border-sys-accent-1 hover:text-sys-accent-1 text-[11px] transition-all"
      >
        {tag}
      </button>
    ))}
  </div>

  <!-- Featured post (first) -->
  {featured && (
    <a
      href={`/blog/${featured.slug}`}
      data-tags={JSON.stringify(featured.data.tags)}
      class="post-card featured-card group block mb-10 border border-sys-border hover:border-sys-accent-1/60 transition-all bg-sys-surface/20 hover:bg-sys-surface/40 overflow-hidden relative"
    >
      <!-- Glow effect -->
      <div class="absolute inset-0 bg-gradient-to-br from-sys-accent-1/5 via-transparent to-sys-accent-2/5 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>

      <div class="relative z-10 p-8 sm:p-10 grid grid-cols-1 sm:grid-cols-[1fr_auto] gap-6 items-start">
        <div>
          <!-- Tags -->
          <div class="flex gap-2 flex-wrap mb-4">
            {featured.data.tags.map(tag => (
              <span class="px-2 py-0.5 text-[10px] font-mono border border-sys-accent-1/30 text-sys-accent-1 bg-sys-accent-1/8">
                {tag}
              </span>
            ))}
          </div>
          <h2 class="text-2xl sm:text-3xl font-black font-sans text-white mb-3 group-hover:text-sys-accent-1 transition-colors leading-snug">
            {featured.data.title}
          </h2>
          <p class="text-sys-muted font-sans text-sm leading-relaxed max-w-2xl">
            {featured.data.description}
          </p>
        </div>
        <div class="flex sm:flex-col items-center sm:items-end gap-4 sm:gap-2 shrink-0">
          <span class="text-[11px] font-mono text-sys-muted">{featured.data.date}</span>
          <span class="text-xs font-mono text-sys-accent-1 border border-sys-accent-1/40 px-2 py-0.5 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap">
            read →
          </span>
        </div>
      </div>
    </a>
  )}

  <!-- Grid of remaining posts -->
  {rest.length > 0 && (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" id="posts-grid">
      {rest.map(post => (
        <a
          href={`/blog/${post.slug}`}
          data-tags={JSON.stringify(post.data.tags)}
          class="post-card group border border-sys-border hover:border-sys-accent-1/50 transition-all bg-sys-surface/20 hover:bg-sys-surface/40 flex flex-col overflow-hidden relative"
        >
          <div class="absolute inset-0 bg-gradient-to-br from-sys-accent-1/3 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
          <div class="relative z-10 p-6 flex flex-col h-full">
            <!-- Tags -->
            <div class="flex gap-1.5 flex-wrap mb-3">
              {post.data.tags.map(tag => (
                <span class="px-1.5 py-0.5 text-[9px] font-mono border border-sys-border text-sys-muted">
                  {tag}
                </span>
              ))}
            </div>
            <!-- Title -->
            <h2 class="text-[15px] font-bold font-sans text-white leading-snug mb-2 group-hover:text-sys-accent-1 transition-colors flex-grow">
              {post.data.title}
            </h2>
            <p class="text-sys-muted text-[12px] font-sans leading-relaxed line-clamp-2 mb-4">
              {post.data.description}
            </p>
            <!-- Footer -->
            <div class="flex items-center justify-between mt-auto pt-3 border-t border-sys-border/40 text-[10px] font-mono">
              <span class="text-sys-muted">{post.data.date}</span>
              <span class="text-sys-accent-1 opacity-0 group-hover:opacity-100 transition-opacity">read →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}

  {allPosts.length === 0 && (
    <div class="text-center py-20 text-sys-muted font-mono text-sm">
      <p>No posts yet.</p>
    </div>
  )}

</div>

<footer class="border-t border-sys-border py-6 text-center text-[10px] font-mono text-sys-muted">
  &copy; 2026 martes.app
</footer>

</Layout>

<script is:inline>
(function () {
  var buttons  = document.querySelectorAll('.tag-btn');
  var featured = document.querySelector('.featured-card');
  var cards    = document.querySelectorAll('.post-card:not(.featured-card)');

  function filter(tag) {
    // Buttons
    buttons.forEach(function (btn) {
      var active = btn.getAttribute('data-tag') === tag;
      btn.classList.toggle('border-sys-accent-1', active);
      btn.classList.toggle('text-sys-accent-1', active);
      btn.classList.toggle('border-sys-border', !active);
      btn.classList.toggle('text-sys-muted', !active);
    });

    // Featured
    if (featured) {
      var fTags = JSON.parse(featured.getAttribute('data-tags') || '[]');
      featured.style.display = (!tag || fTags.includes(tag)) ? '' : 'none';
    }

    // Grid cards
    cards.forEach(function (card) {
      if (!tag) { card.style.display = ''; return; }
      var tags = JSON.parse(card.getAttribute('data-tags') || '[]');
      card.style.display = tags.includes(tag) ? '' : 'none';
    });
  }

  buttons.forEach(function (btn) {
    btn.addEventListener('click', function () { filter(btn.getAttribute('data-tag') || ''); });
  });
})();
</script>