---
const WA = 'https://wa.me/584149189169';
const WA_TEXT = '?text=Hola%2C%20quiero%20probar%20martes';
---
<section id="contacto" class="py-24 sm:py-32">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8 flex justify-center">
      <span class="ve-eyebrow" data-c="t1">// 11 // Contacto</span>
    </div>
    <h2 class="ve-title text-4xl sm:text-5xl lg:text-6xl font-sans font-extrabold leading-[1.1] tracking-tight mb-8 text-center" data-c="t1">
      Listo para <span class="font-black italic">dejar el caos</span>?
    </h2>
    <p class="ve-lead mb-12 max-w-2xl mx-auto text-center">Escribenos por WhatsApp o dejanos tus datos y te contactamos. 30 minutos, sin compromiso.</p>

    <!-- Contact form -> Lark -->
    <div class="max-w-xl mx-auto mb-12">
      <form id="contact-form-ve" class="space-y-4" novalidate>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <input id="cf-name-ve" name="name" type="text" required
            placeholder="Tu nombre"
            class="w-full bg-ve-surface border border-ve-border text-ve-text placeholder-ve-muted px-4 py-3 text-sm font-mono focus:outline-none focus:border-ve-purple transition-colors" />
          <input id="cf-biz-ve" name="business" type="text"
            placeholder="Tu negocio (opcional)"
            class="w-full bg-ve-surface border border-ve-border text-ve-text placeholder-ve-muted px-4 py-3 text-sm font-mono focus:outline-none focus:border-ve-purple transition-colors" />
        </div>
        <input id="cf-phone-ve" name="phone" type="tel"
          placeholder="WhatsApp / telefono"
          class="w-full bg-ve-surface border border-ve-border text-ve-text placeholder-ve-muted px-4 py-3 text-sm font-mono focus:outline-none focus:border-ve-purple transition-colors" />
        <textarea id="cf-msg-ve" name="message" rows="3"
          placeholder="Que necesitas automatizar?"
          class="w-full bg-ve-surface border border-ve-border text-ve-text placeholder-ve-muted px-4 py-3 text-sm font-mono focus:outline-none focus:border-ve-purple transition-colors resize-none"></textarea>
        <button type="submit" id="cf-btn-ve"
          class="w-full bg-ve-purple text-white font-bold uppercase tracking-[0.15em] py-4 text-sm hover:bg-ve-purple-deep transition-colors"
          style="box-shadow: 0 8px 30px -8px rgba(124,58,237,0.5);">
          Enviar mensaje
        </button>
        <p id="cf-status-ve" class="text-center text-xs font-mono min-h-[1.2em]"></p>
      </form>
    </div>

    <!-- WhatsApp CTA -->
    <div class="text-center">
      <p class="text-ve-muted text-xs font-mono mb-4 uppercase tracking-wider">O escribenos directamente:</p>
      <a href={`${WA}${WA_TEXT}`} target="_blank" rel="noopener"
         class="inline-flex items-center justify-center px-10 py-5 bg-ve-purple text-white hover:bg-ve-purple-deep font-semibold uppercase tracking-[0.15em] transition-all text-sm shadow-lg"
         style="box-shadow: 0 8px 30px -8px rgba(124,58,237,0.5);">
        Hablar por WhatsApp
        <svg class="ml-3 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </a>
    </div>

    <div class="mt-16 text-center">
      <div class="ve-eyebrow" data-c="t5">
        Hecho en Venezuela · para Venezuela · con orgullo
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  // TODO: replace with your real Lark incoming webhook URL
  // Get it from: Lark -> Group -> Bot -> Add bot -> Webhook Bot -> Copy URL
  var LARK_WEBHOOK = 'LARK_WEBHOOK_URL_PLACEHOLDER';
  var form   = document.getElementById('contact-form-ve');
  var btn    = document.getElementById('cf-btn-ve');
  var status = document.getElementById('cf-status-ve');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var name    = (form.querySelector('[name=name]').value || '').trim();
    var biz     = (form.querySelector('[name=business]').value || '').trim();
    var phone   = (form.querySelector('[name=phone]').value || '').trim();
    var message = (form.querySelector('[name=message]').value || '').trim();
    if (!name || !message) {
      status.textContent = 'Nombre y mensaje son requeridos.';
      status.style.color = '#ec4899';
      return;
    }
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    status.textContent = '';
    var payload = {
      msg_type: 'post',
      content: {
        post: {
          es_es: {
            title: 'Nuevo contacto - martes.app VE',
            content: [
              [{ tag: 'text', text: 'Nombre: ' + name }],
              [{ tag: 'text', text: 'Negocio: ' + (biz || '-') }],
              [{ tag: 'text', text: 'Telefono: ' + (phone || '-') }],
              [{ tag: 'text', text: 'Mensaje: ' + message }],
              [{ tag: 'text', text: 'Origen: martes.app (Venezuela)' }]
            ]
          }
        }
      }
    };
    fetch(LARK_WEBHOOK, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.code === 0) {
        status.textContent = 'Mensaje enviado. Te contactamos pronto!';
        status.style.color = '#00ffcc';
        form.reset();
      } else {
        throw new Error(data.msg || 'Error');
      }
    })
    .catch(function() {
      status.textContent = 'Error al enviar. Escribenos por WhatsApp.';
      status.style.color = '#ec4899';
    })
    .finally(function() {
      btn.disabled = false;
      btn.textContent = 'Enviar mensaje';
    });
  });
})();
</script>
