---
import Layout from './LayoutUS.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title:        string;
  description?: string;
  date?:        string;
  tags?:        string[];
  author?:      string;
}

const { title, description, date, tags = [], author } = Astro.props;

const recent = (await getCollection('blog'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 5);
---

<Layout title={`${title} — Blog martes.app`} description={description}>
  <slot />
</Layout>
