---
import Layout from './LayoutUS.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title:        string;
  description?: string;
  date?:        string;
  tags?:        string[];
  author?:      string;
}

const { title, description, date, tags = [], author } = Astro.props;

const recent = (await getCollection('blog'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 5);
---

<Layout title={`${title} — Blog martes.app`} description={description}>

<!-- NAV -->
<header class="fixed top-0 w-full z-40 border-b border-sys-border bg-sys-bg/95 backdrop-blur-md">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
    <div class="flex items-center gap-3 min-w-0">
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="w-1.5 h-1.5 bg-sys-accent-1 rounded-full"></span>
        <span class="font-bold tracking-widest uppercase text-xs font-mono text-sys-text">martes<span class="text-sys-accent-1">.app</span></span>
      </a>
      <span class="text-sys-border">/</span>
      <a href="/blog" class="text-sys-muted text-xs font-mono hover:text-sys-accent-1 transition-colors shrink-0">Blog</a>
      <span class="text-sys-border hidden sm:inline">/</span>
      <span class="text-sys-text text-xs font-mono truncate hidden sm:inline">{title}</span>
    </div>
    <a href="/#contacto" class="bg-sys-accent-1 text-black px-3 py-1.5 font-bold uppercase tracking-wider hover:bg-white transition-colors text-[10px] shrink-0">
      Contacto
    </a>
  </div>
</header>

<div class="pt-14 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 grid grid-cols-1 lg:grid-cols-[1fr_260px] gap-14">
  <article class="min-w-0">
    <div class="mb-10">
      {tags.length > 0 && (
        <div class="flex gap-2 mb-5 flex-wrap">
          {tags.map(tag => (
            <a href={`/blog?tag=${tag}`} class="px-2.5 py-0.5 text-[10px] font-mono border border-sys-accent-1/40 text-sys-accent-1 hover:bg-sys-accent-1/10 transition-colors">{tag}</a>
          ))}
        </div>
      )}
      <h1 class="text-[34px] sm:text-[40px] font-black font-sans text-white leading-tight mb-5">{title}</h1>
      {description && <p class="text-sys-muted font-sans text-base leading-relaxed mb-5">{description}</p>}
      <div class="flex items-center gap-4 text-[11px] font-mono text-sys-muted border-t border-sys-border pt-4">
        {date && <span>{date}</span>}
        {author && <span>·</span>}
        {author && <span>{author}</span>}
      </div>
    </div>
    <div class="prose-blog"><slot /></div>
    <div class="mt-14 pt-8 border-t border-sys-border flex items-center justify-between">
      <a href="/blog" class="text-xs font-mono text-sys-muted hover:text-sys-accent-1 transition-colors flex items-center gap-1.5">← todos los artículos</a>
      <a href="/#contacto" class="text-xs font-mono text-sys-accent-1 border border-sys-accent-1/40 px-3 py-1.5 hover:bg-sys-accent-1/10 transition-colors">¿Tienes un proyecto? →</a>
    </div>
  </article>
  <aside class="hidden lg:block">
    <div class="sticky top-20">
      <p class="text-[9px] font-mono text-sys-muted uppercase tracking-[0.15em] mb-4 border-b border-sys-border pb-2">Artículos recientes</p>
      <div class="space-y-3">
        {recent.map(post => (
          <a href={`/blog/${post.slug}`} class="block p-3 border border-sys-border hover:border-sys-accent-1/50 hover:bg-sys-surface/40 transition-all group">
            <div class="text-[11px] font-sans text-sys-text font-medium group-hover:text-sys-accent-1 transition-colors leading-snug mb-1">{post.data.title}</div>
            <div class="text-[9px] font-mono text-sys-muted">{post.data.date}</div>
          </a>
        ))}
      </div>
    </div>
  </aside>
</div>
<footer class="border-t border-sys-border py-6 text-center text-[10px] font-mono text-sys-muted">&copy; 2026 martes.app</footer>
</Layout>
