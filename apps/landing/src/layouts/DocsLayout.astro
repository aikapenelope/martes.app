---
import Layout from './Layout.astro';
import { getCollection } from 'astro:content';

export interface Props {
  title:        string;
  description?: string;
  currentSlug?: string;
}

const { title, description, currentSlug } = Astro.props;

const allDocs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
const sections: Record<string, typeof allDocs> = {};
for (const doc of allDocs) {
  const s = doc.data.section;
  if (!sections[s]) sections[s] = [];
  sections[s].push(doc);
}

// Anterior / Siguiente para navegación inline
const flat = allDocs;
const idx  = flat.findIndex(d => d.slug === currentSlug);
const prev = idx > 0 ? flat[idx - 1] : null;
const next = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null;
---

<Layout title={`${title} — Docs`} description={description}>
<style is:global>
  /* Scroll suave para anchors internos */
  html { scroll-behavior: smooth; }
</style>

<!-- NAV SUPERIOR -->
<header class="fixed top-0 w-full z-40 border-b border-sys-border bg-sys-bg/95 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between gap-4">
    <div class="flex items-center gap-4 min-w-0">
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="w-1.5 h-1.5 bg-sys-accent-1 rounded-full"></span>
        <span class="text-sys-text font-bold tracking-widest uppercase text-xs font-mono">martes.app</span>
      </a>
      <span class="text-sys-border">/</span>
      <a href="/docs" class="text-sys-muted text-xs font-mono hover:text-sys-accent-1 transition-colors shrink-0">Docs</a>
      {currentSlug && (
        <>
          <span class="text-sys-border">/</span>
          <span class="text-sys-text text-xs font-mono truncate">{title}</span>
        </>
      )}
    </div>
    <div class="flex items-center gap-4 shrink-0 text-xs font-mono">
      <a href="/blog"     class="text-sys-muted hover:text-sys-accent-1 transition-colors hidden sm:block">Blog</a>
      <a href="/#contacto" class="bg-sys-accent-1 text-black px-3 py-1.5 font-bold uppercase tracking-wider hover:bg-white transition-colors text-[10px]">
        Contacto
      </a>
    </div>
  </div>
</header>

<div class="flex pt-14 min-h-screen">

  <!-- SIDEBAR -->
  <aside class="hidden lg:flex flex-col w-60 shrink-0 border-r border-sys-border/60 bg-sys-bg">
    <div class="sticky top-14 overflow-y-auto h-[calc(100vh-3.5rem)] py-6 px-4">

      <!-- Volver al hub -->
      <a href="/docs" class="flex items-center gap-2 text-[11px] font-mono text-sys-muted hover:text-sys-accent-1 transition-colors mb-6 group">
        <span class="group-hover:-translate-x-0.5 transition-transform">←</span>
        <span>Documentación</span>
      </a>

      {Object.entries(sections).map(([section, docs]) => (
        <div class="mb-5">
          <div class="text-[9px] text-sys-muted uppercase tracking-widest font-mono mb-2 px-2">
            {section}
          </div>
          <nav>
            {docs.map(doc => (
              <a
                href={`/docs/${doc.slug}`}
                class={[
                  'flex items-center gap-2 px-2 py-1.5 rounded text-[12px] font-mono transition-all',
                  currentSlug === doc.slug
                    ? 'bg-sys-accent-1/10 text-sys-accent-1 border-l-2 border-sys-accent-1 pl-3'
                    : 'text-sys-muted hover:text-sys-text hover:bg-sys-surface/60',
                ].join(' ')}
              >
                {currentSlug === doc.slug && <span class="w-1 h-1 rounded-full bg-sys-accent-1 shrink-0"></span>}
                {doc.data.title}
              </a>
            ))}
          </nav>
        </div>
      ))}
    </div>
  </aside>

  <!-- CONTENIDO PRINCIPAL -->
  <div class="flex-1 min-w-0 flex flex-col">
    <main class="flex-1 max-w-3xl mx-auto w-full px-6 lg:px-10 py-12">

      <!-- Breadcrumb mobile -->
      <div class="lg:hidden flex items-center gap-2 text-[11px] font-mono text-sys-muted mb-8">
        <a href="/docs" class="hover:text-sys-accent-1 transition-colors">Docs</a>
        {currentSlug && <><span>/</span><span class="text-sys-text">{title}</span></>}
      </div>

      <!-- Header del artículo -->
      <div class="mb-10 pb-8 border-b border-sys-border">
        <h1 class="text-[32px] font-black font-sans text-white leading-tight mb-3">{title}</h1>
        {description && <p class="text-sys-muted text-base leading-relaxed">{description}</p>}
      </div>

      <!-- Contenido Markdown -->
      <div class="prose-docs">
        <slot />
      </div>

      <!-- Navegación anterior / siguiente -->
      <div class="mt-16 pt-8 border-t border-sys-border grid grid-cols-2 gap-4">
        {prev ? (
          <a href={`/docs/${prev.slug}`} class="group p-4 border border-sys-border hover:border-sys-accent-1/50 transition-all text-left">
            <div class="text-[9px] font-mono text-sys-muted uppercase tracking-widest mb-1 flex items-center gap-1">
              <span>←</span> Anterior
            </div>
            <div class="text-sm text-sys-text group-hover:text-sys-accent-1 transition-colors font-medium">{prev.data.title}</div>
          </a>
        ) : <div></div>}
        {next && (
          <a href={`/docs/${next.slug}`} class="group p-4 border border-sys-border hover:border-sys-accent-1/50 transition-all text-right">
            <div class="text-[9px] font-mono text-sys-muted uppercase tracking-widest mb-1 flex items-center gap-1 justify-end">
              Siguiente <span>→</span>
            </div>
            <div class="text-sm text-sys-text group-hover:text-sys-accent-1 transition-colors font-medium">{next.data.title}</div>
          </a>
        )}
      </div>

    </main>

    <footer class="border-t border-sys-border py-5 text-center text-[10px] font-mono text-sys-muted">
      &copy; 2026 martes.app
    </footer>
  </div>

</div>
</Layout>
